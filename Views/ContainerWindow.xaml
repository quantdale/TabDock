<Window x:Class="TabDock.Views.ContainerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:infra="clr-namespace:TabDock.Infrastructure"
        mc:Ignorable="d"
        Title="{Binding Name}"
        Height="600"
        Width="900"
        MinWidth="320"
        MinHeight="240"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{Binding AccentBrush}"
        Name="Root">

    <Window.Resources>
        <Style TargetType="Button" x:Key="CaptionButtonStyle">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe UI Symbol" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        </Style>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="6"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom caption -->
        <Grid Height="32" Background="{Binding AccentBrush}" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Accent color chip / color picker -->
            <Button Grid.Column="0" Width="16" Height="16" Margin="12,0,8,0"
                    Background="{Binding AccentBrush}" BorderBrush="White" BorderThickness="1"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    ToolTip="Change accent color" Click="ColorChip_Click">
                <Button.ContextMenu>
                    <ContextMenu x:Name="ColorContextMenu">
                        <MenuItem Header="Blue" Click="ColorMenuItem_Click" Tag="#2196F3" />
                        <MenuItem Header="Green" Click="ColorMenuItem_Click" Tag="#4CAF50" />
                        <MenuItem Header="Red" Click="ColorMenuItem_Click" Tag="#F44336" />
                        <MenuItem Header="Purple" Click="ColorMenuItem_Click" Tag="#9C27B0" />
                        <MenuItem Header="Orange" Click="ColorMenuItem_Click" Tag="#FF9800" />
                        <MenuItem Header="Teal" Click="ColorMenuItem_Click" Tag="#009688" />
                        <MenuItem Header="Pink" Click="ColorMenuItem_Click" Tag="#E91E63" />
                        <MenuItem Header="Gray" Click="ColorMenuItem_Click" Tag="#607D8B" />
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>

            <!-- IsHitTestVisibleInChrome is required on every interactive caption
                 element: the WindowChrome CaptionHeight region otherwise consumes
                 all clicks as non-client hits (a title double-click maximized the
                 window instead of starting a rename). -->
            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                       Foreground="White" FontSize="12" FontWeight="SemiBold"
                       WindowChrome.IsHitTestVisibleInChrome="True"
                       MouseLeftButtonDown="TitleText_MouseLeftButtonDown">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Visibility is driven entirely by the style Setter + IsRenaming
                 DataTrigger below. Do NOT set Visibility as a local attribute here:
                 a local value outranks style/trigger setters, so the trigger could
                 never show the box (the box stayed collapsed forever). -->
            <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=LostFocus}"
                     VerticalAlignment="Center" BorderThickness="0" Background="White"
                     Foreground="Black" Padding="4,2"
                     WindowChrome.IsHitTestVisibleInChrome="True"
                     x:Name="RenameBox"
                     LostFocus="RenameBox_LostFocus"
                     KeyDown="RenameBox_KeyDown">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- Add window to group -->
            <Button Grid.Column="3" Style="{StaticResource CaptionButtonStyle}"
                    Content="&#xE710;" Click="AddWindow_Click" ToolTip="Add window to group" />

            <Button Grid.Column="4" Style="{StaticResource CaptionButtonStyle}"
                    Content="&#xE949;" Click="Minimize_Click" ToolTip="Minimize" />
            <Button Grid.Column="5" Style="{StaticResource CaptionButtonStyle}"
                    Content="&#xE739;" Click="Maximize_Click" ToolTip="Maximize/Restore" x:Name="MaximizeButton" />
            <Button Grid.Column="6" Style="{StaticResource CaptionButtonStyle}"
                    Content="&#xE106;" Click="Close_Click" ToolTip="Close" />
        </Grid>

        <!-- Tab strip -->
        <Border Grid.Row="1" Background="#22000000" Height="32">
            <ListBox x:Name="TabsListBox"
                     ItemsSource="{Binding Tabs}"
                     SelectedItem="{Binding ActiveTab, Mode=OneWay}"
                     SelectionChanged="TabsListBox_SelectionChanged"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="2,2,0,2" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="IsSelected" Value="{Binding IsActive, Mode=TwoWay}" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8,4" CornerRadius="4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                            <Setter Property="Background" Value="#44FFFFFF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding Title}" Foreground="White" VerticalAlignment="Center" MaxWidth="160" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Pop out" Command="{Binding PopOutCommand}" />
                                    <MenuItem Header="Close window" Command="{Binding CloseWindowCommand}" />
                                </ContextMenu>
                            </Border.ContextMenu>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Content host -->
        <Border Grid.Row="2" Background="#FF1E1E1E" x:Name="ContentBorder">
            <infra:NativeHwndHost x:Name="ContentHost"
                                  ActiveWindow="{Binding ActiveTabContent, Mode=OneWay}" />
        </Border>
    </Grid>
</Window>
